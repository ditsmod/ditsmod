{
  "private": true,
  "name": "ditsmod",
  "type": "module",
  "version": "1.0.0",
  "description": "monorepo for ditsmod projects",
  "engines": {
    "node": ">= 20.6.0"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "experiments/*"
  ],
  "scripts": {
    "test": "yarn build-test && yarn esm-jest",
    "test-authjs": "yarn build-authjs-test && vitest",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)",
    "test-examples": "tsgo -b examples/tsconfig.e2e.json && yarn esm-jest -c examples/jest.config.ts",
    "test-all": "yarn test && yarn test-authjs && yarn test-examples && yarn build-vscode",
    "pub": "lerna publish from-package --pre-dist-tag next",
    "build": "tsgo -b packages",
    "build-test": "tsgo -b packages/tsconfig.test.json",
    "build-authjs-test": "tsgo -b packages/authjs/tsconfig.e2e.json",
    "build-examples": "tsgo -b examples/tsconfig.build.json",
    "build-exam-test": "tsgo -b examples/tsconfig.e2e.json",
    "build-vscode": "tsgo -b examples/tsconfig.vscode.json",
    "lint": "eslint .",
    "clean": "rm -r packages/*/dist* examples/*/dist*",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "publish": "yarn build && yarn changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ditsmod/ditsmod.git"
  },
  "keywords": [
    "ditsmod",
    "monorepo"
  ],
  "author": "Костя Третяк",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ditsmod/ditsmod/issues"
  },
  "homepage": "https://github.com/ditsmod/ditsmod#readme",
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/supertest": "^7.2.0",
    "@typescript/native-preview": "^7.0.0-dev.20260511.1",
    "eslint": "^10.0.3",
    "jest": "^30.4.2",
    "lerna": "8.2.4",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@4.14.1"
}
