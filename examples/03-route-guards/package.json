{
  "private": true,
  "name": "example03",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "start": "yarn build && node --watch --enable-source-maps -r dotenv/config dist/main.js",
    "clean": "rm -r dist*",
    "start:dev": "ditsmod start",
    "test": "yarn build-test && yarn esm-jest",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)",
    "build": "tsgo -b tsconfig.build.json",
    "build-test": "tsgo -b tsconfig.e2e.json"
  },
  "imports": {
    "#app/*": "./dist/app/*",
    "#auth": "./dist/app/modules/auth/index.js"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@ditsmod/cli": "^3.0.0-next.13",
    "@typescript/native-preview": "^7.0.0-dev.20260626.1",
    "jest": "^30.4.2"
  }
}
