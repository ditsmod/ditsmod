{
  "private": true,
  "name": "example18-client",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "start": "run-p dev:server dev:client --print-label",
    "start:dev": "run-p dev:server dev:client --print-label",
    "dev:server": "ditsmod start --project ../18-trpc-server/tsconfig.build.json --entry-file ../18-trpc-server/dist/main.js",
    "dev:client": "yarn wait-port 2021 && ditsmod start dist/client.js",
    "clean": "rm -r dist*",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)",
    "build-test": "tsgo -b tsconfig.e2e.json",
    "build": "tsgo -b tsconfig.build.json"
  },
  "imports": {
    "#app/*": "./dist/app/*",
    "#post/*": "./dist/app/modules/post/*",
    "#comments/*": "./dist/app/modules/post/comments/*",
    "#db/*": "./dist/app/modules/db/*",
    "#auth/*": "./dist/app/modules/auth/*",
    "#message/*": "./dist/app/modules/message/*"
  },
  "devDependencies": {
    "@ditsmod/cli": "^3.0.0-next.13",
    "@typescript/native-preview": "^7.0.0-dev.20260626.1",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "start-server-and-test": "^2.1.5",
    "typescript": "^5.9.3",
    "wait-port": "^1.1.0"
  },
  "dependencies": {
    "@trpc/client": "^11.5.1",
    "@trpc/server": "^11.5.1",
    "zod": "^4.4.3"
  }
}
