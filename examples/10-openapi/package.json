{
  "private": true,
  "name": "example10",
  "type": "module",
  "version": "1.0.0",
  "license": "MIT",
  "module": "dist/index.js",
  "scripts": {
    "start": "ditsmod start",
    "clean": "rm -r dist*",
    "test": "yarn build-test && yarn esm-jest",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)",
    "build-test": "tsc -b tsconfig.e2e.json",
    "build": "tsc -b tsconfig.build.json",
    "rebuild": "cd ../.. && yarn clean && cd - && yarn build"
  },
  "imports": {
    "#app/*": "./dist/app/*",
    "#routed/*": "./dist/app/modules/routed/*",
    "#service/*": "./dist/app/modules/service/*"
  },
  "devDependencies": {
    "@ditsmod/cli": "^3.0.0-next.14",
    "jest": "^30.4.2",
    "typescript-7": "npm:typescript@^7.0.2"
  }
}
