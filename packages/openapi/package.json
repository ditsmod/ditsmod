{
  "name": "@ditsmod/openapi",
  "type": "module",
  "version": "3.0.0-next.8",
  "repository": {
    "type": "git",
    "url": "https://github.com/ditsmod/ditsmod.git",
    "directory": "packages/openapi"
  },
  "description": "This is module for Ditsmod framework to support OpenAPI",
  "module": "dist/index.js",
  "imports": {
    "#types/*": "./dist/types/*",
    "#utils/*": "./dist/utils/*",
    "#decorators/*": "./dist/decorators/*",
    "#services/*": "./dist/services/*",
    "#constants": "./dist/constants.js",
    "#errors": "./dist/errors.js"
  },
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    }
  },
  "scripts": {
    "build": "tsgo -b tsconfig.build.json",
    "build-ui": "yarn build && node dist/swagger-ui/compile.js",
    "clean": "rm -rf dist*",
    "build-test": "tsgo -b tsconfig.unit.json",
    "test": "yarn build-test && yarn esm-jest",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)"
  },
  "keywords": [
    "ditsmod"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ts-stack/openapi-spec": "^3.1.6",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/swagger-ui": "^5.32.0",
    "@typescript/native-preview": "^7.0.0-dev.20260501.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.4.2",
    "json-loader": "^0.5.7",
    "npm-run-all": "^4.1.5",
    "style-loader": "^4.0.0",
    "swagger-ui": "~5.27.1",
    "webpack": "^5.106.2",
    "yaml-loader": "^0.8.1"
  },
  "peerDependencies": {
    "@ditsmod/core": "^3.0.0-next.8",
    "@ditsmod/rest": "^3.0.0-next.8"
  },
  "gitHead": "eaf8f20b4e75e38c7a51fd1c3174b691cea756fa"
}
