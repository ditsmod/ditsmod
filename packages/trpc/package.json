{
  "name": "@ditsmod/trpc",
  "type": "module",
  "version": "3.0.0-next.13",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ditsmod/ditsmod.git"
  },
  "homepage": "https://ditsmod.github.io/en/",
  "description": "Ditsmod module to support tRPC.",
  "module": "dist/index.js",
  "imports": {
    "#errors": "./dist/errors.js",
    "#decorators/*": "./dist/decorators/*",
    "#init/*": "./dist/init/*",
    "#types/*": "./dist/types/*",
    "#utils/*": "./dist/utils/*",
    "#providers/*": "./dist/providers/*",
    "#services/*": "./dist/services/*",
    "#extensions/*": "./dist/extensions/*",
    "#interceptors/*": "./dist/interceptors/*"
  },
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist*",
    "test": "tsc -b tsconfig.unit.json && yarn esm-jest",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)"
  },
  "keywords": [
    "ditsmod",
    "trpc"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@ditsmod/core": "^3.0.0-next.13",
    "@trpc/server": "^11.5.0"
  },
  "devDependencies": {
    "@trpc/server": "^11.18.0",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "typescript-7": "npm:typescript@^7.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "eaf8f20b4e75e38c7a51fd1c3174b691cea756fa"
}
