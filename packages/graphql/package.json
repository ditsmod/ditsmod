{
  "private": true,
  "name": "@ditsmod/graphql",
  "type": "module",
  "version": "3.0.0-alpha.5",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ditsmod/ditsmod.git"
  },
  "homepage": "https://ditsmod.github.io/en/",
  "description": "Ditsmod module to support GraphQL",
  "module": "dist/index.js",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -b tsconfig.build.json",
    "clean": "rm -rf dist*",
    "test": "tsgo -b tsconfig.unit.json && yarn esm-jest",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)"
  },
  "keywords": [
    "ditsmod"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "@apollo/server": "^5.0.0",
    "@ditsmod/core": "^3.0.0-next.13",
    "graphql": "^16.11.0"
  },
  "devDependencies": {
    "@typescript/native-preview": "^7.0.0-dev.20260617.2",
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
