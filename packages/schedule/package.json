{
  "name": "@ditsmod/schedule",
  "type": "module",
  "version": "3.0.0-next.15",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ditsmod/ditsmod.git"
  },
  "homepage": "https://ditsmod.github.io/en/",
  "description": "Ditsmod module to support...",
  "module": "dist/index.js",
  "imports": {
    "#src/*": "./dist/*"
  },
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "clean": "rm -rf dist*",
    "test": "yarn build-test && yarn esm-jest",
    "build-test": "tsc -b tsconfig.e2e.json",
    "esm-jest": "yarn node --experimental-vm-modules --no-warnings=ExperimentalWarning --enable-source-maps $(yarn bin jest)"
  },
  "keywords": [
    "ditsmod",
    "schedule"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cron": "4.4.0"
  },
  "peerDependencies": {
    "@ditsmod/core": "^3.0.0-next.15"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "npm-run-all": "^4.1.5",
    "typescript-7": "npm:typescript@^7.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
